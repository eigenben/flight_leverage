---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Flight Leverage: Techniques in Travel Hacking',
  description = 'A blog about travel hacking techniques and strategies for earning and redeeming airline miles and hotel points.',
} = Astro.props;

const siteTitle = 'Flight Leverage';
const defaultTitle = 'Flight Leverage: Techniques in Travel Hacking';
const pageTitle = title === defaultTitle ? title : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/feed.xml" />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <Header />
    <main class="max-w-3xl mx-auto px-6 py-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
