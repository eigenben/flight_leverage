---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<Base title={title}>
  <article>
    <header class="mb-8">
      <time class="text-sm text-gray-500" datetime={date.toISOString()}>
        {formattedDate}
      </time>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 leading-tight">
        {title}
      </h1>
    </header>
    <div class="prose prose-lg prose-gray max-w-none prose-img:rounded-lg prose-a:text-blue-600">
      <slot />
    </div>
    <footer class="mt-12 pt-8 border-t border-gray-200">
      <a href="/" class="text-blue-600 hover:text-blue-800 transition-colors">
        &larr; Back to all posts
      </a>
    </footer>
  </article>
</Base>
