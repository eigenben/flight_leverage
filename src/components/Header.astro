---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/feed.xml', label: 'RSS' },
];
---

<header class="border-b border-gray-200 bg-white/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="group">
      <h1 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
        Flight Leverage
      </h1>
      <p class="text-sm text-gray-500">Techniques in Travel Hacking</p>
    </a>
    <nav class="flex gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-gray-600 hover:text-blue-600 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
